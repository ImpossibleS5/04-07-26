---
import { wedding } from '../data/wedding'
---

<section class="rsvp section" id="rsvp">
  <div class="container">
    <h2 class="section-title">Подтвердите присутствие</h2>
    <div class="divider">
      <svg viewBox="0 0 60 12" width="56" height="12" aria-hidden="true">
        <g stroke="currentColor" stroke-width="0.8" fill="none" stroke-linecap="round">
          <path d="M30 1 L30 11"/>
          <path d="M30 4 C 24 2 18 2 12 5"/>
          <path d="M30 4 C 36 2 42 2 48 5"/>
        </g>
        <ellipse cx="14" cy="5.5" rx="3" ry="1" transform="rotate(-30 14 5.5)" fill="currentColor"/>
        <ellipse cx="46" cy="5.5" rx="3" ry="1" transform="rotate(30 46 5.5)" fill="currentColor"/>
        <circle cx="30" cy="11" r="1.2" fill="currentColor"/>
      </svg>
    </div>

    <p class="rsvp__lead">
      Пожалуйста, дайте знать, сможете ли вы быть с&nbsp;нами в&nbsp;этот особенный день
    </p>

    <a
      class="rsvp__cta"
      href={wedding.rsvp.formUrl}
      target="_blank"
      rel="noopener noreferrer"
    >
      Открыть форму подтверждения
    </a>

    <p class="rsvp__hint">Откроется на отдельной странице</p>
  </div>
</section>

<style>
  .rsvp { text-align: center; }
  .rsvp__lead {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 17px;
    color: var(--ink-secondary);
    margin: 0 auto 36px;
    max-width: 380px;
    line-height: 1.55;
  }
  .rsvp__cta {
    display: inline-block;
    background: var(--accent-rose);
    color: #fff;
    border: none;
    border-radius: var(--radius-pill);
    padding: 16px 36px;
    font-family: var(--font-engraved);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    border-bottom: none;
    box-shadow: var(--shadow-soft);
    transition:
      background 180ms var(--ease-out),
      transform 160ms var(--ease-press),
      box-shadow 200ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .rsvp__cta:hover {
      background: var(--accent-rose-deep);
      box-shadow: var(--shadow-card);
      border-bottom-color: transparent;
    }
  }
  .rsvp__cta:active { transform: scale(0.97); }
  .rsvp__hint {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 14px;
    color: var(--ink-muted);
    margin: 18px 0 0;
  }
</style>
